rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /sightings/{sightingId} {
      allow read: if resource.data.approved == true
        || (request.auth != null && request.auth.token.email == "eddieskehan@gmail.com");

      allow create: if request.resource.data.approved == false
        && request.resource.data.photoUrl is string
        && request.resource.data.city is string
        && request.resource.data.country is string
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && (request.resource.data.name == null || request.resource.data.name is string)
        && (request.resource.data.state == null || request.resource.data.state is string)
        && (request.resource.data.notes == null || request.resource.data.notes is string)
        && (request.resource.data.locationName == null || request.resource.data.locationName is string)
        && request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    match /growRequests/{requestId} {
      allow create: if request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0;

      allow read, update, delete: if false;
    }

    match /adminDevices/{token} {
      allow read, write: if request.auth != null
        && request.auth.token.email == "eddieskehan@gmail.com";
    }

    match /adminConfig/{docId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == "eddieskehan@gmail.com";
    }
  }
}
